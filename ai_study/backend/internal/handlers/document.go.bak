// Document Handler - POST /api/documents/parse
package handlers

import (
	"archive/zip"
	"bytes"
	"encoding/json"
	"fmt"
	"io"
	"log"
	"net/http"
	"os"
	"path/filepath"
	"strings"
)

const maxFileSize = 10 * 1024 * 1024 // 10MB

// DocumentParseResponse represents the response for document parsing.
type DocumentParseResponse struct {
	Summary  string           `json:"summary"`
	Blocks   []DocumentBlock  `json:"blocks"`
	RawText  string           `json:"raw_text"`
}

// DocumentBlock represents a parsed block from a document.
type DocumentBlock struct {
	Type    string `json:"type"`
	Content string `json:"content"`
}

// HandleDocumentParse handles POST /api/documents/parse
// Parses .docx/.pdf files and returns summary, blocks, and raw text.
func HandleDocumentParse(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodPost {
		http.Error(w, "Method Not Allowed", http.StatusMethodNotAllowed)
		return
	}

	// Set max memory for multipart form
	r.Body = http.MaxBytesReader(w, r.Body, maxFileSize+1024*1024) // +1MB buffer

	if err := r.ParseMultipartForm(maxFileSize); err != nil {
		http.Error(w, `{"error": "File too large (max 10MB) or invalid form data"}`, http.StatusBadRequest)
		return
	}

	file, header, err := r.FormFile("file")
	if err != nil {
		http.Error(w, `{"error": "No file provided in 'file' field"}`, http.StatusBadRequest)
		return
	}
	defer file.Close()

	// Validate file size
	if header.Size > maxFileSize {
		http.Error(w, `{"error": "File too large (max 10MB)"}`, http.StatusBadRequest)
		return
	}

	// Read file content
	content, err := io.ReadAll(file)
	if err != nil {
		http.Error(w, `{"error": "Failed to read file"}`, http.StatusInternalServerError)
		return
	}

	// Get file extension
	ext := strings.ToLower(filepath.Ext(header.Filename))

	// For .md and .txt files, frontend can read directly
	// This endpoint handles .docx and .pdf
	var resp DocumentParseResponse
	switch ext {
	case ".docx":
		resp, err = parseDocx(content)
	case ".pdf":
		resp, err = parsePdf(content)
	case ".md", ".txt":
		// For plain text, return as-is
		resp = DocumentParseResponse{
			Summary:  truncateText(string(content), 200),
			Blocks:   extractPlainTextBlocks(string(content)),
			RawText:  string(content),
		}
		err = nil
	default:
		http.Error(w, `{"error": "Unsupported file type. Use .md, .txt, .docx, or .pdf"}`, http.StatusBadRequest)
		return
	}

	if err != nil {
		log.Printf("Failed to parse document: %v", err)
		http.Error(w, fmt.Sprintf(`{"error": "Failed to parse document: %v"}`, err), http.StatusInternalServerError)
		return
	}

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(resp)
}

// parseDocx parses a .docx file and returns summary, blocks, and raw text.
func parseDocx(content []byte) (DocumentParseResponse, error) {
	reader, err := zip.NewReader(bytes.NewReader(content), int64(len(content)))
	if err != nil {
		return DocumentParseResponse{}, fmt.Errorf("failed to read docx as zip: %w", err)
	}

	var documentXML string
	for _, file := range reader.File {
		if file.Name == "word/document.xml" {
			rc, err := file.Open()
			if err != nil {
				return DocumentParseResponse{}, fmt.Errorf("failed to open document.xml: %w", err)
			}
			data, err := io.ReadAll(rc)
			rc.Close()
			if err != nil {
				return DocumentParseResponse{}, fmt.Errorf("failed to read document.xml: %w", err)
			}
			documentXML = string(data)
			break
		}
	}

	if documentXML == "" {
		return DocumentParseResponse{}, fmt.Errorf("document.xml not found in docx")
	}

	// Extract text from XML using simple string operations
	// In production, use gooxml's xml parser for proper structure
	rawText := extractTextFromDocxXML(documentXML)

	resp := DocumentParseResponse{
		Summary: truncateText(rawText, 200),
		Blocks:  extractDocxBlocks(documentXML),
		RawText: rawText,
	}

	return resp, nil
}

// extractTextFromDocxXML extracts plain text from docx XML content.
func extractTextFromDocxXML(xml string) string {
	// Simple extraction: find all <w:t> tags and concatenate text
	var result strings.Builder
	inTag := false
	_tagDepth := 0
 capturing := false
 capturingText := false

	for i := 0; i < len(xml); i++ {
		c := xml[i]
		if c == '<' {
			inTag = true
			// Check if this is a text tag <w:t
			if i+4 <= len(xml) && xml[i:i+4] == "<w:t" {
				capturing = true
			}
			continue
		}
		if c == '>' {
			inTag = false
			if capturing {
				capturing = false
				capturingText = true
			}
			continue
		}
		if !inTag && capturingText {
			result.WriteByte(c)
		}
	}

	text := result.String()
	// Collapse whitespace
	text = strings.Join(strings.Fields(text), " ")
	return text
}

// extractDocxBlocks extracts structured blocks from docx XML.
func extractDocxBlocks(xml string) []DocumentBlock {
	var blocks []DocumentBlock

	// Find headings
	headings := findDocxElements(xml, "w:pStyle w:val")
	for _, h := range headings {
		style := getDocxAttribute(h, "w:val")
		text := extractTextFromDocxXML(h)
		if text == "" {
			continue
		}
		switch style {
		case "1", "Heading1":
			blocks = append(blocks, DocumentBlock{Type: "heading1", Content: text})
		case "2", "Heading2":
			blocks = append(blocks, DocumentBlock{Type: "heading2", Content: text})
		case "3", "Heading3":
			blocks = append(blocks, DocumentBlock{Type: "heading3", Content: text})
		default:
			blocks = append(blocks, DocumentBlock{Type: "paragraph", Content: text})
		}
	}

	// If no headings found, just add the whole text as a paragraph
	if len(blocks) == 0 {
		text := extractTextFromDocxXML(xml)
		if text != "" {
			blocks = append(blocks, DocumentBlock{Type: "paragraph", Content: text})
		}
	}

	return blocks
}

// findDocxElements finds XML elements containing a specific attribute.
func findDocxElements(xml, attrPattern string) []string {
	// Simplified implementation - returns paragraphs with matching styles
	var results []string
	_tagStack := 0
	var current strings.Builder
	inWTag := false

	for i := 0; i < len(xml); i++ {
		if xml[i] == '<' {
			if inWTag {
				current.WriteByte('<')
			}
			inWTag = true
			current.Reset()
			tagStack = 0
		}

		if inWTag {
			current.WriteByte(xml[i])

			// Check for paragraph start <w:p
			if i+4 < len(xml) && xml[i:i+4] == "<w:p" {
				tagStack = 1
			}

			if xml[i] == '>' {
				// Check if it's a w:p or w:r tag
				s := current.String()
				if strings.HasPrefix(s, "<w:p") || strings.HasPrefix(s, "<w:p ") {
					tagStack = 1
				}
				inWTag = false

				// Find matching closing tag
				if strings.HasPrefix(s, "<w:p") && !strings.HasPrefix(s, "</w:p") {
					// Start collecting this paragraph
					paraStart := i - len(s) + 1
					// Find </w:p>
					endIdx := strings.Index(xml[paraStart:], "</w:p>")
					if endIdx > 0 {
						para := xml[paraStart : paraStart+endIdx+6]
						results = append(results, para)
					}
				}
			}
		}
	}

	return results
}

// getDocxAttribute extracts an attribute value from an XML tag.
func getDocxAttribute(tag, attr string) string {
	pattern := attr + `="`
	idx := strings.Index(tag, pattern)
	if idx < 0 {
		return ""
	}
	start := idx + len(pattern)
	end := strings.Index(tag[start:], `"`)
	if end < 0 {
		return ""
	}
	return tag[start : start+end]
}

// parsePdf parses a PDF file and returns summary, blocks, and raw text.
// This is a placeholder implementation - full PDF parsing requires gopdf or similar.
func parsePdf(content []byte) (DocumentParseResponse, error) {
	// Placeholder: In production, use gopdf or pdfcpu to extract text
	// For now, return the raw bytes as a hex string (not useful but won't crash)
	_rawText := string(content)

	// Simple text extraction attempt: look for text between BT and ET markers
	lines := extractPdfTextLines(content)

	resp := DocumentParseResponse{
		Summary:  fmt.Sprintf("PDF document (%d bytes)", len(content)),
		Blocks:   []DocumentBlock{{Type: "paragraph", Content: strings.Join(lines, "\n")}},
		RawText:  strings.Join(lines, "\n"),
	}

	return resp, nil
}

// extractPdfTextLines attempts to extract text lines from PDF content.
func extractPdfTextLines(content []byte) []string {
	// Very simplified PDF text extraction
	// Looks for text between parentheses in stream content
	var lines []string
	var currentLine strings.Builder
	_inText := false

	data := string(content)
	for i := 0; i < len(data); i++ {
		if data[i] == '(' && i+1 < len(data) && data[i+1] != ')' {
			// Potential text start
			start := i + 1
			for j := start; j < len(data) && j < start+500; j++ {
				if data[j] == ')' {
					text := data[start:j]
					// Clean up escape sequences
					text = strings.ReplaceAll(text, "\\n", "\n")
					text = strings.ReplaceAll(text, "\\r", "\r")
					text = strings.ReplaceAll(text, "\\t", "\t")
					text = strings.ReplaceAll(text, "\\\\", "\\")
					if len(strings.TrimSpace(text)) > 0 {
						if currentLine.Len() > 0 {
							currentLine.WriteString(" ")
						}
						currentLine.WriteString(text)
					}
					break
				}
			}
		}
		if data[i] == '\n' || data[i] == '\r' {
			if currentLine.Len() > 0 {
				line := strings.TrimSpace(currentLine.String())
				if line != "" {
					lines = append(lines, line)
				}
				currentLine.Reset()
			}
		}
	}

	if currentLine.Len() > 0 {
		line := strings.TrimSpace(currentLine.String())
		if line != "" {
			lines = append(lines, line)
		}
	}

	if len(lines) == 0 {
		lines = []string{"[PDF text extraction not available - file may contain images or use non-standard encoding]"}
	}

	return lines
}

// extractPlainTextBlocks extracts blocks from plain text.
func extractPlainTextBlocks(text string) []DocumentBlock {
	lines := strings.Split(text, "\n")
	var blocks []DocumentBlock
	var currentParagraph strings.Builder

	for _, line := range lines {
	 trimmed := strings.TrimSpace(line)
		if trimmed == "" {
			if currentParagraph.Len() > 0 {
				blocks = append(blocks, DocumentBlock{Type: "paragraph", Content: strings.TrimSpace(currentParagraph.String())})
				currentParagraph.Reset()
			}
			continue
		}

		// Check if it's a heading (lines starting with #)
		if strings.HasPrefix(trimmed, "# ") {
			if currentParagraph.Len() > 0 {
				blocks = append(blocks, DocumentBlock{Type: "paragraph", Content: strings.TrimSpace(currentParagraph.String())})
				currentParagraph.Reset()
			}
			blocks = append(blocks, DocumentBlock{Type: "heading1", Content: trimmed[2:]})
		} else if strings.HasPrefix(trimmed, "## ") {
			if currentParagraph.Len() > 0 {
				blocks = append(blocks, DocumentBlock{Type: "paragraph", Content: strings.TrimSpace(currentParagraph.String())})
				currentParagraph.Reset()
			}
			blocks = append(blocks, DocumentBlock{Type: "heading2", Content: trimmed[3:]})
		} else if strings.HasPrefix(trimmed, "### ") {
			if currentParagraph.Len() > 0 {
				blocks = append(blocks, DocumentBlock{Type: "paragraph", Content: strings.TrimSpace(currentParagraph.String())})
				currentParagraph.Reset()
			}
			blocks = append(blocks, DocumentBlock{Type: "heading3", Content: trimmed[4:]})
		} else {
			if currentParagraph.Len() > 0 {
				currentParagraph.WriteString(" ")
			}
			currentParagraph.WriteString(trimmed)
		}
	}

	if currentParagraph.Len() > 0 {
		blocks = append(blocks, DocumentBlock{Type: "paragraph", Content: strings.TrimSpace(currentParagraph.String())})
	}

	return blocks
}

// truncateText truncates text to a maximum length.
func truncateText(text string, maxLen int) string {
	if len(text) <= maxLen {
		return text
	}
	return text[:maxLen] + "..."
}
